# ═══════════════════════════════════════════════════════════════════════
# Driftwood — Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════

# ── Backend (FastAPI) ──────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins
# Use "*" for development, restrict in production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8787

# ── Frontend (Next.js) ────────────────────────────────────────────────
# URL of the Cloudflare Worker (or FastAPI directly for local dev)
WORKER_URL=http://localhost:8000

# Public URL for generating embed snippets
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudflare Worker ─────────────────────────────────────────────────
# FastAPI backend URL (set in wrangler.toml [vars])
# BACKEND_URL=http://localhost:8000

# ── Upstash Redis (For Global Simulation Metrics Tracking) ─────────────
# UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_token_here
